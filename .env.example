# Mapbox public access token (pk.) — used at runtime in MapScreen
# Get yours at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_PUBLIC_TOKEN_HERE

# Mapbox secret download token (sk.) — used in app.json plugin for EAS builds
# Create one at https://account.mapbox.com/access-tokens/ with Downloads:Read scope
# Replace "sk.YOUR_MAPBOX_SECRET_TOKEN" in app.json
